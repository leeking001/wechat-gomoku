/**app.wxss**/
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 20px 0;
  box-sizing: border-box;
}

/* 通用按钮样式 */
button {
  margin: 10px 5px;
  border-radius: 8px;
  font-size: 16px;
  padding: 12px 24px;
  transition: all 0.3s ease;
}

button:hover {
  opacity: 0.8;
}

button.primary {
  background-color: #1E90FF;
  color: white;
}

button.danger {
  background-color: #FF6B6B;
  color: white;
}

button.success {
  background-color: #52C41A;
  color: white;
}

/* 文本样式 */
.text-center {
  text-align: center;
}

.mt-20 {
  margin-top: 20px;
}

.mb-20 {
  margin-bottom: 20px;
}

.p-20 {
  padding: 20px;
}
