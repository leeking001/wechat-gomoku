<view class="container">
  <view class="status">
    <text>{{statusText}}</text>
    <picker mode="selector" range="{{depthOptions}}" bindchange="onDepthChange">
      <view class="picker">难度：{{depth}}</view>
    </picker>
    <button size="mini" bindtap="restart">重新开始</button>
  </view>
  <canvas id="board" canvas-id="board" class="board" style="width:{{canvasWidth}}px;height:{{canvasHeight}}px" bindtouchstart="touch"></canvas>
  <view class="tips">人机对战：你执黑先手，AI执白</view>
</view>